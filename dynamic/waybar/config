[
  {
    "layer": "top",
    "position": "top",
    "height": 30,
    "spacing": 8,
    "modules-left": [
      "hyprland/workspaces"
    ],
    "modules-center": [
      "clock"
    ],
    "modules-right": [
      "pulseaudio",
      "network",
      "battery"
    ],
    "clock": {
      "format": "{:%Y-%m-%d %H:%M}"
    },
    "hyprland/workspaces": {
      "format": "{name}"
    },
    "pulseaudio": {
      "format": "VOL {volume}%",
      "format-muted": "MUTED",
      "scroll-step": 5,
      "on-click": "pavucontrol"
    },
    "network": {
      "format": "{ifname} {ipaddr}",
      "on-click": "alacritty --class nmtui --title nmtui -e nmtui"
    },
    "battery": {
      "format": "BAT {capacity}%",
      "format-charging": "CHR {capacity}%"
    }
  }
]
